#!/usr/bin/env bash
set -euo pipefail

echo "==> go build ./..."
go build ./...

echo "==> go vet ./..."
go vet ./...

echo "==> gofmt check"
unformatted=$(gofmt -l $(find . -name '*.go' -not -path './vendor/*') 2>/dev/null)
if [ -n "$unformatted" ]; then
    echo "ERROR: Files not formatted with gofmt:"
    echo "$unformatted"
    echo "Run: gofmt -w \$file"
    exit 1
fi

# golangci-lint is optional — skip if not installed.
if command -v golangci-lint &>/dev/null; then
    echo "==> golangci-lint run"
    golangci-lint run
else
    echo "==> golangci-lint not found, skipping (install: https://golangci-lint.run/welcome/install/)"
fi

echo "==> All pre-commit checks passed"
